rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /listing-media/{landlordId}/{listingId}/{fileName} {
      allow read: if true;

      allow create, update: if
        isSignedIn() &&
        request.auth.uid == landlordId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');

      allow delete: if isSignedIn() && request.auth.uid == landlordId;
    }
  }
}
